# Ignore everything at the repo root by default.
/*

# Keep only the app code directories and this file in git.
!/.gitignore
!/backend/
!/backend/**
!/frontend/
!/frontend/**

# Python cache and virtualenvs
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.coverage
**/htmlcov/
**/.ipynb_checkpoints/
**/venv/
**/.venv/

# Environment and local databases
**/.env
**/.env.*
**/db.sqlite3
**/db.sqlite3-journal

# Django generated files
**/staticfiles/
**/media/
**/*.log

# Node/Vite artifacts
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*

# OS / editor files
**/.DS_Store
**/.idea/
**/.vscode/
**/*.swp
**/*~

# Python / build artifacts
**/build/
**/dist/
**/*.egg-info/

# Optional local training/runtime artifacts if generated inside kept folders
backend/data/
backend/**/catboost_info/
